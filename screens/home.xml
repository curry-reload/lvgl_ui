<?xml version="1.0" encoding="UTF-8"?>
<screen permanent="true">
    <view
        scrollable="false"
        style_bg_color="0x0f172a"
        style_bg_opa="100%"
        pad_all="24"
        flex_flow="column"
        style_flex_main_place="center"
        style_flex_cross_place="center"
        style_pad_row="18"
    >
        <lv_label
            text="LVGL Pro Simulator"
            style_text_color="0xf8fafc"
            style_text_font="montserrat_24"
        />

        <lv_obj
            width="280"
            pad_all="18"
            style_bg_color="0x1e293b"
            style_bg_opa="100%"
            radius="16"
            border_width="0"
        >
            <lv_label
                text="Drag the slider to verify data binding in preview."
                width="100%"
                style_text_color="0xcbd5e1"
            />

            <lv_slider
                width="100%"
                min_value="0"
                max_value="100"
                bind_value="demo_value"
                y="18"
            />

            <lv_label
                y="36"
                bind_text="demo_value"
                bind_text-fmt="Value: %d"
                style_text_color="0x38bdf8"
            />
        </lv_obj>

        <lv_button
            width="180"
            height="44"
            style_bg_color="0x38bdf8"
            style_bg_opa="100%"
        >
            <lv_label text="Sample Button" style_text_color="0x082f49"/>
        </lv_button>
    </view>
</screen>
